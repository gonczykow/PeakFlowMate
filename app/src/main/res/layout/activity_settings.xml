<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/zonengrenzen_einstellen"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <View android:id="@+id/greenDot"
        android:layout_width="16dp" android:layout_height="16dp"
        android:background="#1D9E75"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvGreenLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/gr_ne_zone_ab_l_min"
        android:textSize="14sp"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@id/greenDot"
        app:layout_constraintBottom_toBottomOf="@id/greenDot"
        app:layout_constraintStart_toEndOf="@id/greenDot"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/etGreen"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:hint="z.B. 400"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/greenDot"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <View android:id="@+id/yellowDot"
        android:layout_width="16dp" android:layout_height="16dp"
        android:background="#EF9F27"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/etGreen"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvYellowLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/gelbe_zone_ab_l_min"
        android:textSize="14sp"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@id/yellowDot"
        app:layout_constraintBottom_toBottomOf="@id/yellowDot"
        app:layout_constraintStart_toEndOf="@id/yellowDot"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/etYellow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:hint="z.B. 300"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/yellowDot"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/rote_zone_alles_unterhalb_der_gelben_zone"
        android:textSize="12sp"
        android:textColor="?android:attr/textColorSecondary"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/etYellow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvReminderLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/erinnerungszeit"
        android:textSize="14sp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnTimePicker"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/uhrzeit_w_hlen"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvReminderLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvSelectedTime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/btnTimePicker"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnSaveSettings"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/speichern1"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvSelectedTime"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>